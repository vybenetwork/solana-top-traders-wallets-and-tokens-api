# Get your API key at https://docs.vybenetwork.com (sign in with a social account for free tier; wallet-only sign-in is restricted to reduce sybil abuse).
# Quick start: https://docs.vybenetwork.com/docs/quick-start
VYBE_API_KEY=your_api_key_here

# Optional: token mint address to demo (defaults to a popular token)
# TOKEN_MINT=DezXAZ8z7PnrnRJjz3wXBoRgixCa6xjnB7YaB1pPB263

# Optional: Solana mainnet RPC for token symbol lookup (Metaplex metadata). Default: https://api.mainnet-beta.solana.com
# SOLANA_RPC_URL=

# Optional: set to 1 to log each /api/trades request to trades-requests.log (default: off)
# TRADES_LOG=0
